Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkB2ZWx0cml4LmNvbSIsInJvbCI6IkFETUlOIiwiaWF0IjoxNzc5NjQ5NDk5LCJleHAiOjE3Nzk3MzU4OTl9.3ZvmutJHc4lwt0BhgXFVsWlmtcShcpZYKgtctdyE2lI


{
  "nombre": "Monitor 4K",
  "descripcion": "Monitor 27 pulgadas",
  "precio": 499.99,
  "stock": 10,
  "categoriaId": 3
}

### ADMIN: Crear categoría
POST http://localhost:8080/api/categorias
Content-Type: application/json
Authorization: Bearer PEGA_TOKEN_ADMIN_AQUI

{
  "nombre": "Componentes",
  "descripcion": "Tarjetas de video y procesadores"
}

### CLIENTE intenta crear producto
POST http://localhost:8080/api/productos
Content-Type: application/json
Authorization: Bearer PEGA_TOKEN_CLIENTE_AQUI

{
  "nombre": "No autorizado",
  "precio": 10,
  "stock": 1,
  "categoriaId": 1
}

